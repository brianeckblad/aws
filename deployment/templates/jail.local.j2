# ============================================================================
# FAIL2BAN CONFIGURATION
# ============================================================================
# Template: deployment/templates/jail.local.j2
# Generated by: harden-server.yml
# Location on server: /etc/fail2ban/jail.local
#
# ⚠️  DO NOT manually edit — will be overwritten on redeploy
#
# Jails configured here:
#   [sshd]     — SSH brute-force protection (deployer IP is always whitelisted)
#
# Jails NOT configured here:
#   [recidive] — DISABLED (see note below)
#
# WHY [recidive] IS DISABLED:
#   recidive bans last 7 days and survive fail2ban restarts (stored in
#   iptables). A stray ban can cascade into a week-long SSH lockout that
#   requires EC2 Instance Connect to clear.
#
# Monitoring:
#   fail2ban-client status        — overall status
#   fail2ban-client status sshd   — per-jail status
#   iptables -L -n                — see banned IPs
#   tail -f /var/log/fail2ban.log — watch banning in action
# ============================================================================

[DEFAULT]
# Ban for 24 hours after 3 failures in a 20-minute window
bantime  = 86400
findtime = 1200
maxretry = 3

# Use port-specific bans — prevents any jail from accidentally blocking SSH.
# (Ubuntu default banaction is iptables-allports which blocks ALL ports
# including 22 when any jail fires.)
banaction = iptables-multiport

# Deployment/admin IPs are never banned.
# deployer_ip is detected at deploy time; admin_ip is set in app vault.yml.
ignoreip = 127.0.0.1/8 ::1{% if deployer_ip | default('') != '' %} {{ deployer_ip }}{% endif %}{% if admin_ip | default('') != '' %} {{ admin_ip }}/32{% endif %}


[sshd]
enabled  = true
port     = ssh
logpath  = %(sshd_log)s
backend  = %(sshd_backend)s
maxretry = 5


[recidive]
# DISABLED: 7-day bans stored in iptables survive fail2ban restarts.
# A stray ban can cascade into a week-long SSH lockout that requires
# EC2 Instance Connect to clear.
enabled = false
