---
# ============================================================================
# DEPLOYMENT CONFIGURATION — SERVER FOUNDATION ONLY
# ============================================================================
# This repo provisions and hardens a shared EC2 server.
# App-level config (git, Flask, gunicorn, S3, SSL, eBay, etc.) lives in
# each application's own vault.yml.
#
# Setup:
#   1. Copy:    cp vault.yml.example vault.yml
#   2. Edit:    nano vault.yml
#   3. Encrypt: ansible-vault encrypt vault.yml --vault-password-file ~/.vault_pass
#
# Edit:    ansible-vault edit group_vars/vault.yml --vault-password-file ~/.vault_pass
# View:    ansible-vault view group_vars/vault.yml --vault-password-file ~/.vault_pass
# ============================================================================


# ============================================================================
# SERVER IDENTITY
# Drives all AWS resource names:
#   EC2 Name tag    → host_name
#   Security group  → {host_name}-sg
#   IAM role        → {host_name}-ec2-role
#   SSH key pair    → {host_name}-key
# ============================================================================
host_name: "your-server-name"   # lowercase, hyphens ok (e.g. web01, prod-server)
admin_user: "ubuntu"            # SSH login user on Ubuntu EC2 AMIs


# ============================================================================
# AWS
# ============================================================================
aws_region: "us-east-2"

# SSH CIDR restriction — applied to the EC2 security group (port 22).
# If not set, defaults to the deployer machine's public IP at provision time.
# Set a fixed CIDR if you have a static office/VPN IP (e.g. "203.0.113.0/24").
# To allow multiple IPs, update the security group rule in AWS after provisioning.
# ssh_allowed_cidr: "YOUR_IP/32"


# ============================================================================
# EC2 INSTANCE
# ============================================================================
ec2_instance_type: "t3.small"       # t3.small handles 2-4 light apps comfortably
assign_public_ip: true
ec2_monitoring_enabled: false        # true = detailed CloudWatch metrics ($)
ec2_termination_protection: true     # Prevent accidental deletion
ec2_ebs_optimized: false
ec2_source_dest_check: true


# ============================================================================
# EBS DATA VOLUME
# Mounted at apps_root — all app code and data live here.
# This volume SURVIVES instance termination (ebs_data_delete_on_termination: false).
# ============================================================================
apps_root: "/opt/apps"               # Parent directory for all app code
logs_root: "/var/log/apps"           # Parent directory for all app logs

ebs_volume_size: 100                 # GB — shared across all apps on this server
ebs_volume_type: "gp3"
ebs_volume_encrypted: true
ebs_boot_delete_on_termination: true    # Root volume deleted on terminate (safe)
ebs_data_delete_on_termination: false   # Data volume SURVIVES terminate (REQUIRED)
ebs_volume_snapshot_id: ""             # Set to restore from an existing snapshot
ebs_device_name: "/dev/sdf"           # EC2 API device name
ebs_nvme_device: "/dev/nvme1n1"       # NVMe path on Nitro instances (t3, m5, etc.)
